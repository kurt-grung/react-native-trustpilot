{
  "name": "react-native-trustpilot",
  "version": "1.0.0",
  "description": "A React Native widget for displaying Trustpilot reviews and ratings",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "scripts": {
    "build": "bob build",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "trustpilot",
    "reviews",
    "widget",
    "ratings"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kurt-grung/react-native-trustpilot.git"
  },
  "author": "kurt-grung",
  "license": "MIT",
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "react-native-webview": ">=11.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-native": "^0.73.0",
    "react": "18.3.1",
    "react-native": "0.76.0",
    "react-native-builder-bob": "^0.30.0",
    "react-native-webview": "^13.0.0",
    "typescript": "^5.4.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  }
}
